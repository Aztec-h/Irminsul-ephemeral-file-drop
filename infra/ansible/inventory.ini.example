# This file is auto-generated by Terraform (see infra/terraform/ec2.tf) into
# inventory.ini at the root of this directory. Copy this example only if you
# want to hand-edit the inventory instead.

[jenkins]
jenkins ansible_host=REPLACE_ME

[k3s_server]
k3s-server ansible_host=REPLACE_ME k3s_server_private_ip=REPLACE_ME

[k3s_agents]
k3s-agent-0 ansible_host=REPLACE_ME

[k3s_cluster:children]
k3s_server
k3s_agents

[all:vars]
ansible_user=ec2-user
ansible_ssh_private_key_file=~/.ssh/irminsul.pem
ansible_ssh_common_args='-o StrictHostKeyChecking=no'
k3s_server_url=https://REPLACE_ME:6443
s3_bucket=REPLACE_ME
aws_region=us-east-1
rds_endpoint=REPLACE_ME
rds_port=5432
rds_database=irminsul
rds_username=irminsul
